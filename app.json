{
  "expo": {
    "name": "羽毛球教练",
    "slug": "badminton-trainer",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "badminton",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1220"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.you.badmintontrainer",
      "infoPlist": {
        "NSCameraUsageDescription": "需要使用摄像头识别羽毛球动作",
        "NSMicrophoneUsageDescription": "录像复盘时需要录音",
        "NSPhotoLibraryUsageDescription": "用于导入对战录像"
      }
    },
    "android": {
      "package": "com.you.badmintontrainer",
      "backgroundColor": "#0B1220",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#10B981"
      },
      "navigationBar": {
        "visible": "sticky",
        "backgroundColor": "#0B1220",
        "barStyle": "light-content"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "需要使用摄像头识别羽毛球动作",
          "enableMicrophonePermission": true,
          "microphonePermissionText": "录像复盘时需要录音"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#10B981"
        }
      ],
      "expo-font",
      "react-native-fast-tflite"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "07019ed4-b74e-48c3-9f02-09cc5112589a"
      }
    },
    "owner": "fengbojing"
  }
}
